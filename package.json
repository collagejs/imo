{
  "name": "@collagejs/imo",
  "private": false,
  "version": "0.2.1",
  "type": "module",
  "description": "Performs import map entry overriding for ES modules, and posts the resulting import map to Vite development servers.",
  "keywords": [
    "collagejs",
    "import-map",
    "import-maps",
    "micro-frontend",
    "micro-frontends",
    "vite"
  ],
  "author": {
    "email": "webJose@gmail.com",
    "name": "José Pablo Ramírez Vargas"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/collagejs/imo.git"
  },
  "bugs": {
    "url": "https://github.com/collagejs/imo/issues"
  },
  "license": "MIT",
  "homepage": "https://collagejs.dev",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./const": {
      "types": "./dist/const.d.ts",
      "import": "./dist/const.js",
      "default": "./dist/const.js"
    },
    "./imo": {
      "import": "./dist/imo.min.js"
    },
    "./css": {
      "import": "./dist/assets/cjcss(cjs-imo)index.css"
    }
  },
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build && pwsh post-build.ps1 && publint",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "test": "vitest",
    "test:ci": "npx playwright install chromium && vitest"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tsconfig/svelte": "^5.0.6",
    "@types/node": "^25.0.3",
    "@typescript-eslint/types": "^8.50.1",
    "@vitest/browser-playwright": "^4.1.7",
    "playwright": "^1.60.0",
    "publint": "^0.3.16",
    "svelte": "^5.43.8",
    "svelte-check": "^4.3.4",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@collagejs/core": "^0.x || ^1.x",
    "@collagejs/importmap": "^0.2.0",
    "@collagejs/svelte": "^0.2.0",
    "@collagejs/vite-css": "^0.x || ^1.x",
    "lucide-svelte": "^0.562.0",
    "p-retry": "^8.0.0",
    "svelte-persisted-state": "^1.2.0",
    "svelte-toggle": "^4.0.1",
    "wj-config": "^3.2.1"
  }
}
